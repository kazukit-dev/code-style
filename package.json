{
  "name": "code-style",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check:fmt": "oxfmt --check .",
    "fix:fmt": "oxfmt --write .",
    "typecheck": "tsc --noEmit",
    "release:oxlint-config": "bun run --filter @kazukit/oxlint-config release"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.46.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
