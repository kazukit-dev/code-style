{
  "name": "@kazukit/oxfmt-config",
  "version": "0.0.2",
  "description": "Shared oxfmt configuration",
  "keywords": [
    "code-style",
    "config",
    "formatter",
    "oxfmt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazukit-dev/code-style.git",
    "directory": "packages/oxfmt-config"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "oxfmt": "^0.46.0 || ^0.50.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
